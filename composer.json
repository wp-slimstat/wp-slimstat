{
  "name": "wp-slimstat/wp-slimstat",
  "description": "The leading web analytics plugin for WordPress",
  "homepage": "https://wp-slimstat.com/",
  "license": "MIT",
  "config": {
    "platform-check": false
  },
  "repositories": [
    {
      "type": "path",
      "url": "packages/veronalabs-browscap-php",
      "options": {
        "symlink": false
      }
    }
  ],
  "autoload": {
    "psr-4": {
      "SlimStat\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WpSlimstat\\Tests\\": "tests/"
    }
  },
  "require": {
    "veronalabs/browscap-php": "dev-standalone"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "brain/monkey": "^2.6",
    "mockery/mockery": "^1.6"
  },
  "extra": {
    "mozart": {
      "dep_namespace": "SlimStat\\Dependencies\\",
      "dep_directory": "/src/Dependencies/",
      "classmap_directory": "/src/",
      "classmap_prefix": "SlimStat_",
      "packages": [
        "veronalabs/browscap-php",
        "league/flysystem"
      ],
      "delete_vendor_directories": true
    }
  },
  "scripts": {
    "post-install-cmd": [
      "~/.composer/vendor/bin/mozart compose",
      "composer dump-autoload"
    ],
    "post-update-cmd": [
      "~/.composer/vendor/bin/mozart compose",
      "composer dump-autoload"
    ],
    "build:autoload": "composer dump-autoload --no-dev --classmap-authoritative",
    "test:license-tags": "php tests/license-tag-gating-test.php",
    "test:geoip-resolver": "php tests/resolve-geolocation-provider-test.php",
    "test:geoservice": "php tests/geoservice-provider-resolution-test.php",
    "test:legacy-sync": "php tests/legacy-sync-mapping-test.php",
    "test:lazy-migration": "php tests/lazy-migration-test.php",
    "test:content-type-attachment": "php tests/content-type-attachment-test.php",
    "test:rest-controller": "php tests/tracking-rest-controller-test.php",
    "test:reports-escaping": "php tests/reports-output-escaping-test.php",
    "test:fingerprint-sanitize": "php tests/fingerprint-sanitization-test.php",
    "test:gdpr-consent": "php tests/gdpr-consent-cookie-test.php",
    "test:user-exclusion": "php tests/user-exclusion-processor-test.php",
    "test:ajax-resource-fix": "php tests/ajax-resource-fix-test.php",
    "test:js-banner-gdpr": "php tests/js-params-banner-gdpr-consistency-test.php",
    "test:v5460-migration": "php tests/v5460-settings-migration-test.php",
    "test:early-translation": "php tests/early-translation-test.php",
    "test:tracker-health-auth": "php tests/tracker-health-auth-test.php",
    "test:browscap-isolation": "php tests/browscap-settings-isolation-test.php",
    "test:dnt-gdpr": "php tests/dnt-gdpr-independence-test.php",
    "test:unit": "phpunit --configuration phpunit.xml.dist",
    "test:all": [
      "@test:unit",
      "@test:license-tags",
      "@test:geoip-resolver",
      "@test:geoservice",
      "@test:legacy-sync",
      "@test:lazy-migration",
      "@test:content-type-attachment",
      "@test:rest-controller",
      "@test:reports-escaping",
      "@test:fingerprint-sanitize",
      "@test:gdpr-consent",
      "@test:user-exclusion",
      "@test:ajax-resource-fix",
      "@test:js-banner-gdpr",
      "@test:v5460-migration",
      "@test:early-translation",
      "@test:tracker-health-auth",
      "@test:browscap-isolation",
      "@test:dnt-gdpr"
    ]
  }
}
