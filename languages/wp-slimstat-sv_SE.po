# @ wp-slimstat
#: admin/config/index.php:88 admin/view/wp-slimstat-db.php:110
#: admin/view/wp-slimstat-db.php:1366 admin/view/wp-slimstat-db.php:1372
#: admin/view/wp-slimstat-db.php:1378 admin/view/wp-slimstat-db.php:1384
